"""
Signal handlers for {{ app_name }} app.

These handlers automatically populate Django models from FormKit submissions.
"""

import logging
from django.db.models.signals import post_save
from formkit_ninja.form_submission.models import SeparatedSubmission
from formkit_ninja.form_submission.signals import (
    import_success,
    import_error
)
from formkit_ninja.form_submission.utils import update_foreign_keys

from . import models

logger = logging.getLogger(__name__)

{% for node in nodepaths %}
{% if node.is_group and not node.is_child %}
def populate_{{ node.classname }}(instance, created):
    """
    Populate {{ node.classname }} model from submission.
    """
    data = instance.fields.copy()
    
    # Update foreign keys/field names
    update_foreign_keys(models.{{ node.classname }}, data)
    
    # Add submission link
    data["submission_id"] = instance.pk
    
    # Create or update
    model_instance, created = models.{{ node.classname }}.objects.update_or_create(
        submission_id=instance.pk,
        defaults=data
    )
    return model_instance, created

{% endif %}
{% endfor %}

@receiver(post_save, sender=SeparatedSubmission)
def handle_separated_submission(sender, instance, created, **kwargs):
    """
    Handle SeparatedSubmission creation/update.
    """
    # Dispatch based on form_type
    {% for node in nodepaths %}
    {% if node.is_group and not node.is_child %}
    if instance.form_type == "{{ node.node.name or node.node.label }}": 
        try:
            model_instance, was_created = populate_{{ node.classname }}(instance, created)
            import_success.send(
                sender=instance.__class__,
                instance=instance,
                model_instance=model_instance,
                was_created=was_created
            )
            logger.info(f"Populated {{ node.classname }} for submission {instance.pk}")
        except Exception as e:
            logger.error(f"Error populating {{ node.classname }}: {e}")
            import_error.send(
                sender=instance.__class__,
                instance=instance,
                error=e
            )
        return
    {% endif %}
    {% endfor %}
    
    # If we get here, no matching form type was found in this app
    pass
